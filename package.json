{
  "name": "auroratube",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AuroraTube: YouTube-compatible frontend and streaming backend with parallel Invidious fallback, yt-dlp, ffmpeg, React, and Tailwind.",
  "scripts": {
    "start": "node src/server.js",
    "build:frontend": "vite build --config frontend/vite.config.js",
    "build": "npm run build:frontend"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
